[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.2
reloadable = true

[libraries]
macos.debug   = "res://addons/better_rng/libgodot_better_rng.dylib"
macos.release = "res://addons/better_rng/libgodot_better_rng.dylib"
linux.debug.x86_64   = "res://addons/better_rng/libgodot_better_rng.so"
linux.release.x86_64 = "res://addons/better_rng/libgodot_better_rng.so"
windows.debug.x86_64   = "res://addons/better_rng/godot_better_rng.dll"
windows.release.x86_64 = "res://addons/better_rng/godot_better_rng.dll"
